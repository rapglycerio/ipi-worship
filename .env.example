# =============================================================
# IPI Worship — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no Git.
# =============================================================

# --- Supabase ---
# Encontre em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-publica>

# --- NextAuth ---
# Gere um secret forte: openssl rand -base64 32
NEXTAUTH_SECRET=<string-aleatoria-forte>
# Em dev: http://localhost:3000  |  Em produção: https://seu-dominio.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth ---
# Console: https://console.developers.google.com/apis/credentials
# Authorized redirect URIs: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
